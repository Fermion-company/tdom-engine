{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "tdom-engine",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "while true; do TDOM_MAX_CHECKPOINTS=24 node server.js; echo \"[respawn] server exited ($?), restarting in 2s\"; sleep 2; done"
      ],
      "port": 4633
    },
    {
      "name": "tdom-engine-alt",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "PORT=4644 TDOM_WORKDIR=.tdom-v3-alt exec node server.js"
      ],
      "port": 4644
    },
    {
      "name": "tdom-engine-hotpath",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "PORT=4655 TDOM_WORKDIR=.tdom-v3-hotpath exec node server.js"
      ],
      "port": 4655
    },
    {
      "name": "tdom-engine-ship",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "PORT=4666 TDOM_WORKDIR=.tdom-v3-shipdev TDOM_SHIP=1 exec node server.js"
      ],
      "port": 4666
    }
  ]
}